{
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron/backup", "schedule": "0 3 * * *" },
    { "path": "/api/cron/adhesion-relances", "schedule": "0 8 * * *" },
    { "path": "/api/cron/vote-relances", "schedule": "0 9 * * *" },
    { "path": "/api/cron/formation-suppressions", "schedule": "0 6 * * *" },
    { "path": "/api/cron/ads-expiration", "schedule": "0 7 * * *" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/profil.html", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/assets/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
